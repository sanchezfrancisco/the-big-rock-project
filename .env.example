# Semantic Code Navigator is local-first.
# External provider keys are intentionally unused by default.

SCN_INDEX_PATH=.scn/index.sqlite3
SCN_EMBEDDING_CACHE_PATH=.scn/embeddings_cache.sqlite3
SCN_MAX_FILE_BYTES=512000
SCN_VECTOR_DIMENSIONS=256
SCN_DEFAULT_TOP_K=5
SCN_EMBEDDING_BACKEND=local
SCN_HYBRID_KEYWORD_WEIGHT=0.35
SCN_OPENAI_EMBED_MODEL=text-embedding-3-small
